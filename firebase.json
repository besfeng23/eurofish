{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(css|js)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
          { "key": "X-Content-Type-Options", "value": "nosniff" }
        ]
      },
      {
        "source": "**/*.@(html|json|webmanifest|xml|txt)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=300" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
          { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self' mailto:" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/company-profile", "destination": "/profile.html" },
      { "source": "/company-profile/**", "destination": "/profile.html" },
      { "source": "/procurement-documents", "destination": "/documents.html" },
      { "source": "/procurement-documents/**", "destination": "/documents.html" },
      { "source": "/milkfish-fry-importer-philippines", "destination": "/milkfish.html" },
      { "source": "/milkfish-fry-importer-philippines/**", "destination": "/milkfish.html" },
      { "source": "/imported-flowers-philippines", "destination": "/flowers.html" },
      { "source": "/imported-flowers-philippines/**", "destination": "/flowers.html" },
      { "source": "/admin", "destination": "/admin.html" },
      { "source": "/admin/**", "destination": "/admin.html" }
    ],
    "cleanUrls": true,
    "trailingSlash": false
  }
}
